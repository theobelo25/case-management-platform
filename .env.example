# Copy to ".env" in the repo root (docker compose loads it automatically).
# Postgres (docker compose "postgres" service)
POSTGRES_USER=casemgmt
POSTGRES_PASSWORD=casemgmt_dev
POSTGRES_DB=casemanagement
POSTGRES_PORT=5432

# When running the API on your machine (not in Docker), point at the compose Postgres:
# ConnectionStrings__DefaultConnection=Host=localhost;Port=5432;Database=casemanagement;Username=casemgmt;Password=casemgmt_dev

# JWT signing key (required for the API). Use a long random string in real deployments.
# For local dev you can use user-secrets or set this env var when using profile "full".
JWT_SIGNING_KEY=dev-only-change-me-use-at-least-64-characters-for-hmac-signing-key-xxxxxxxx

# One-shot demo (Postgres + API, migrations + demo@example.local user): pnpm demo
# or:  scripts/demo.sh   |   scripts\demo.cmd
