{
  "Cors": {
    "AllowedOrigins": ["http://localhost:4200"]
  },
  "Database": {
    "ConnectionString": "Host=localhost;Port=5432;Database=case_management;Username=postgres;Password=YOUR_PASSWORD"
  },
  "Jwt": {
    "Issuer": "case-management-api",
    "Audience": "case-management-web",
    "Secret": "use-a-long-random-secret-at-least-32-characters",
    "ExpiryMinutes": 5,
    "RefreshToken": {
      "CookieName": "refresh_token",
      "ExpiryDays": 14,
      "CookiePath": "/auth"
    }
  }
}
