{
  "Database": {
    "ApplyMigrationsOnStart": false
  },
  "Demo": {
    "Seed": false
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "Hsts": {
    "Enabled": false,
    "MaxAgeDays": 365,
    "IncludeSubDomains": true,
    "Preload": false,
    "ExcludedHosts": []
  },
  "Cors": {
    "AllowedOrigins": []
  },
  "Jwt": {
    "Issuer": "CaseManagement",
    "Audience": "CaseManagement",
    "AccessTokenLifetimeMinutes": 15
  },
  "RateLimiting": {
    "AuthPermitLimit": 20,
    "AuthWindowSeconds": 60,
    "CasesPermitLimit": 20,
    "CasesWindowSeconds": 60
  },
  "ForwardedHeaders": {
    "Enabled": false,
    "ForwardLimit": 2,
    "IncludeHostHeader": false,
    "ReplaceKnownNetworksAndProxies": false,
    "KnownProxies": [],
    "KnownNetworks": []
  },
  "DueSoonScheduler": {
    "Enabled": true,
    "PollIntervalSeconds": 300,
    "BatchSize": 200,
    "AssigneeWindowsMinutes": [ 240, 60, 15 ],
    "PrivilegedWindowsMinutes": [ 15 ],
    "NotifyRequester": false
  }
}
