{
  "AllowedHosts": "localhost;127.0.0.1;[::1]",
  "Hsts": {
    "Enabled": false
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "Jwt": {
    "Issuer": "CaseManagement",
    "Audience": "CaseManagement",
    "AccessTokenLifetimeMinutes": 15
  },
  "Cors": {
    "AllowedOrigins": ["http://localhost:4200"]
  },
  "RateLimiting": {
    "AuthPermitLimit": 20,
    "AuthWindowSeconds": 60,
    "CasesPermitLimit": 20,
    "CasesWindowSeconds": 60
  },
  "ForwardedHeaders": {
    "Enabled": false
  },
  "DueSoonScheduler": {
    "Enabled": true,
    "PollIntervalSeconds": 300,
    "BatchSize": 200,
    "AssigneeWindowsMinutes": [ 240, 60, 15 ],
    "PrivilegedWindowsMinutes": [ 15 ],
    "NotifyRequester": false
  }
}
