FROM mcr.microsoft.com/dotnet/sdk:10.0

WORKDIR /workspace

COPY apps/api/src/CaseManagement.Domain/CaseManagement.Domain.csproj apps/api/src/CaseManagement.Domain/
COPY apps/api/src/CaseManagement.Application/CaseManagement.Application.csproj apps/api/src/CaseManagement.Application/
COPY apps/api/src/CaseManagement.Infrastructure/CaseManagement.Infrastructure.csproj apps/api/src/CaseManagement.Infrastructure/
COPY apps/api/src/CaseManagement.Api/CaseManagement.Api.csproj apps/api/src/CaseManagement.Api/

RUN dotnet restore apps/api/src/CaseManagement.Api/CaseManagement.Api.csproj

COPY apps/api/ apps/api/

WORKDIR /workspace/apps/api/src/CaseManagement.Api

ENV ASPNETCORE_URLS=http://0.0.0.0:5202
EXPOSE 5202

CMD ["dotnet", "watch", "run", "--no-launch-profile"]
